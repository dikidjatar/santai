# Warna-warna
isi HIJAU   = "\033[92m"
isi KUNING  = "\033[93m"
isi CYAN    = "\033[96m"
isi MAGENTA = "\033[95m"
isi MERAH   = "\033[91m"
isi PUTIH   = "\033[0m"
isi ABU_ABU = "\033[90m"
isi BIRU    = "\033[94m"
isi TEBAL   = "\033[1m"
isi RESET   = PUTIH