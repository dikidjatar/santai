{
  "private": true,
  "name": "santai",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "build:watch": "tsc -b -w --preserveWatchOutput",
    "clean": "node scripts/clean.mjs",
    "typecheck": "tsc -b --pretty false",
    "test": "pnpm -r test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && pnpm publish -r --access public"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
