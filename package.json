{
  "private": true,
  "name": "santai",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "build:watch": "tsc -b -w --preserveWatchOutput",
    "dev": "yarn build:watch",
    "clean": "node scripts/clean.mjs",
    "test": "yarn workspaces run test",
    "test:watch": "yarn workspaces run test --watch",
    "typecheck": "tsc -b --pretty false"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
