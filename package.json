{
  "private": true,
  "name": "santai",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b -w",
    "clean": "node scripts/clean.mjs",
    "test": "pnpm -r --if-present test",
    "changeset": "changeset",
    "release:version": "changeset version",
    "publish:core": "pnpm --filter @dikidjatar/santai-core publish --access public",
    "publish:santai-lang": "pnpm --filter santai-lang publish --access public",
    "publish:all": "pnpm publish:core && pnpm publish:santai-lang",
    "release": "pnpm test && pnpm build && pnpm release:version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
