{
  "name": "@dikidjatar/santai-core",
  "version": "2.1.0",
  "description": "core runtime Santai language",
  "type": "commonjs",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json -w --preserveWatchOutput",
    "test": "jest",
    "clean": "node ../../scripts/clean.mjs",
    "prepack": "pnpm build"
  }
}
