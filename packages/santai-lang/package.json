{
  "name": "santai-lang",
  "version": "1.0.0",
  "type": "commonjs",
  "description": "Bahasa pemrograman Santai dengan sintaks dalam bahasa Indonesia",
  "homepage": "https://github.com/dikidjatar/santai-lang#readme",
  "bugs": {
    "url": "https://github.com/dikidjatar/santai-lang/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dikidjatar/santai-lang.git"
  },
  "license": "MIT",
  "author": "Diki Djatar",
  "main": "dist/index.js",
  "bin": {
    "santai": "dist/index.js"
  },
  "dependencies": {
    "@dikidjatar/santai-core": "workspace:*"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json -w",
    "clean": "node ../../scripts/clean.mjs",
    "start": "node dist/index.js",
    "prepack": "pnpm build"
  }
